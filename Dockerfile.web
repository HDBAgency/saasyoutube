FROM node:20-alpine

RUN apk add --no-cache python3 py3-pip ffmpeg && pip3 install --break-system-packages -U yt-dlp

WORKDIR /app

COPY package*.json ./
COPY apps/web/package*.json apps/web/
COPY apps/worker/package*.json apps/worker/
COPY packages/db/package*.json packages/db/
COPY packages/shared/package*.json packages/shared/

RUN npm ci

COPY . .

RUN node -e "const fs=require('fs');let s=fs.readFileSync('packages/db/prisma/schema.prisma','utf8');s=s.replace('provider = \"prisma-client-js\"','provider = \"prisma-client-js\"\n  binaryTargets = [\"native\", \"linux-musl-openssl-3.0.x\"]');fs.writeFileSync('packages/db/prisma/schema.prisma',s);"

RUN npx prisma generate --schema=packages/db/prisma/schema.prisma

RUN npm run build --workspace=packages/db

ARG NEXT_PUBLIC_ADSENSE_CLIENT_ID
ARG NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR
ARG NEXT_PUBLIC_ADSENSE_SLOT_HEADER
ARG NEXT_PUBLIC_ADSENSE_SLOT_INTERSTITIAL
ARG NEXT_PUBLIC_BASE_URL
ARG NEXT_PUBLIC_AD_COUNTDOWN_SECONDS
ENV NEXT_PUBLIC_ADSENSE_CLIENT_ID=$NEXT_PUBLIC_ADSENSE_CLIENT_ID
ENV NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=$NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR
ENV NEXT_PUBLIC_ADSENSE_SLOT_HEADER=$NEXT_PUBLIC_ADSENSE_SLOT_HEADER
ENV NEXT_PUBLIC_ADSENSE_SLOT_INTERSTITIAL=$NEXT_PUBLIC_ADSENSE_SLOT_INTERSTITIAL
ENV NEXT_PUBLIC_BASE_URL=$NEXT_PUBLIC_BASE_URL
ENV NEXT_PUBLIC_AD_COUNTDOWN_SECONDS=$NEXT_PUBLIC_AD_COUNTDOWN_SECONDS
RUN npm run build --workspace=apps/web

EXPOSE 3000

CMD ["npm", "run", "start", "--workspace=apps/web"]
